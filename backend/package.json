{
    "name": "iu-docc-project-secure-software-implementation-backend",
    "description": "Backend for the Social Recipe App",
    "author": "Marcel Frey",
    "version": "1.0.0",
    "private": true,
    "keywords": [
        "backend",
        "nodejs",
        "hono"
    ],
    "type": "module",
    "scripts": {
        "format": "biome format --write .",
        "format:verify": "biome format .",
        "lint": "biome lint --write .",
        "lint-unsafe": "biome lint --unsafe --write .",
        "lint:verify": "biome lint .",
        "typecheck": "tsc -noEmit",
        "test:unit": "vitest run",
        "dev": "tsx watch src/index.ts",
        "build": "tsc",
        "start": "node dist/index.js"
    },
    "dependencies": {
        "@hono/node-server": "^1.19.0",
        "hono": "^4.9.5",
        "jose": "^6.1.0",
        "pg": "^8.14.1",
        "pino": "^9.9.0",
        "reflect-metadata": "^0.2.2",
        "typeorm": "0.3.26"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.2.4",
        "@types/node": "^20.11.17",
        "tsx": "^4.7.1",
        "typescript": "^5.8.3",
        "vitest": "^3.2.4"
    }
}
