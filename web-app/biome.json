{
    "$schema": "https://biomejs.dev/schemas/2.2.4/schema.json",
    "files": {
        "ignoreUnknown": false,
        "includes": ["**", "!dist", "!node_modules"]
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4,
        "lineWidth": 120
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true
        }
    },
    "assist": { "actions": { "source": { "organizeImports": "on" } } }
}
