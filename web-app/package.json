{
    "name": "iu-docc-project-secure-software-implementation-web-app",
    "description": "Web Application for the Social Recipe App",
    "author": "Marcel Frey",
    "version": "1.0.0",
    "private": true,
    "keywords": [
        "website",
        "react",
        "nextui"
    ],
    "type": "module",
    "scripts": {
        "format": "biome format --write .",
