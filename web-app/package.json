        "@heroui/image": "^2.2.15",
        "@heroui/input": "^2.4.25",
        "@heroui/link": "^2.2.21",
        "@heroui/modal": "^2.2.21",
        "@heroui/navbar": "^2.2.22",
        "@heroui/number-input": "^2.0.15",
        "@heroui/pagination": "^2.2.22",
